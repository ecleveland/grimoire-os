datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ── Enums ──────────────────────────────────────────────

enum Role {
  player
  dungeon_master
  admin
}

enum CampaignStatus {
  active
  paused
  completed
  archived
}

enum NoteVisibility {
  private
  party
  dm_only
}

enum AuditAction {
  create
  update
  delete
}

// ── Users ──────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  displayName  String
  email        String?  @unique
  avatarUrl    String?
  role         Role     @default(player)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedCampaigns Campaign[]       @relation("CampaignOwner")
  campaigns      CampaignPlayer[]
  characters     Character[]
  notes          Note[]
  encounters     Encounter[]

  @@map("users")
}

// ── Campaigns ──────────────────────────────────────────

model Campaign {
  id             String         @id @default(uuid())
  name           String
  description    String?
  ownerId        String
  status         CampaignStatus @default(active)
  setting        String?
  currentSession Int            @default(0)
  inviteCode     String?        @unique
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  owner      User             @relation("CampaignOwner", fields: [ownerId], references: [id])
  players    CampaignPlayer[]
  characters Character[]
  notes      Note[]
  encounters Encounter[]

  @@map("campaigns")
}

model CampaignPlayer {
  campaignId String
  userId     String

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([campaignId, userId])
  @@map("campaign_players")
}

// ── Characters ─────────────────────────────────────────

model Character {
  id                String   @id @default(uuid())
  name              String
  userId            String
  campaignId        String?
  race              String?
  class             String?
  level             Int      @default(1)
  subclass          String?
  background        String?
  alignment         String?
  experiencePoints  Int      @default(0)
  abilityScores     Json?
  hitPoints         Json?
  deathSaves        Json?
  armorClass        Int?
  speed             Int?
  initiative        Int?
  proficiencies     String[]
  languages         String[]
  savingThrows      String[]
  skills            String[]
  spellcastingAbility String?
  spellSaveDC       Int?
  spellAttackBonus  Int?
  knownSpells       String[]
  preparedSpells    String[]
  spellSlots        Json?
  inventory         Json?
  currency          Json?
  features          Json?
  personalityTraits String?
  ideals            String?
  bonds             String?
  flaws             String?
  backstory         String?
  appearance        String?
  avatarUrl         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id])
  campaign Campaign? @relation(fields: [campaignId], references: [id])

  @@map("characters")
}

// ── Notes ──────────────────────────────────────────────

model Note {
  id            String         @id @default(uuid())
  title         String
  content       String?
  campaignId    String
  authorId      String
  visibility    NoteVisibility @default(private)
  sessionNumber Int?
  tags          String[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id])
  author   User     @relation(fields: [authorId], references: [id])

  @@map("notes")
}

// ── Encounters ─────────────────────────────────────────

model Encounter {
  id          String   @id @default(uuid())
  name        String
  campaignId  String
  createdById String
  combatants  Json?
  currentTurn Int      @default(0)
  round       Int      @default(1)
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  campaign  Campaign @relation(fields: [campaignId], references: [id])
  createdBy User     @relation(fields: [createdById], references: [id])

  @@map("encounters")
}

// ── SRD Data ───────────────────────────────────────────

model Spell {
  id            String   @id @default(uuid())
  name          String   @unique
  level         Int
  school        String
  castingTime   String
  range         String
  components    String
  duration      String
  description   String
  classes       String[]
  ritual        Boolean  @default(false)
  concentration Boolean  @default(false)
  material      String?
  higherLevels  String?
  source        String   @default("SRD 5.2.1")

  @@index([level])
  @@index([school])
  @@map("spells")
}

model Monster {
  id                    String   @id @default(uuid())
  name                  String   @unique
  size                  String
  type                  String
  subtype               String?
  alignment             String?
  armorClass            Int
  armorType             String?
  hitPoints             Int
  hitDice               String?
  speed                 String
  str                   Int
  dex                   Int
  con                   Int
  int                   Int
  wis                   Int
  cha                   Int
  savingThrows          Json?
  skills                Json?
  damageResistances     String[]
  damageImmunities      String[]
  damageVulnerabilities String[]
  conditionImmunities   String[]
  senses                String?
  languages             String?
  challengeRating       Float
  experiencePoints      Int?
  specialAbilities      Json?
  actions               Json?
  reactions             Json?
  legendaryActions      Json?
  description           String?
  source                String   @default("SRD 5.2.1")

  @@index([type])
  @@index([challengeRating])
  @@map("monsters")
}

model Item {
  id                  String   @id @default(uuid())
  name                String   @unique
  category            String
  cost                String?
  weight              Float?
  description         String?
  damage              String?
  damageType          String?
  armorClass          Int?
  stealthDisadvantage Boolean  @default(false)
  strengthRequirement Int?
  properties          String[]
  rarity              String?
  requiresAttunement  Boolean  @default(false)
  isMagic             Boolean  @default(false)
  source              String   @default("SRD 5.2.1")

  @@index([category])
  @@map("items")
}

model SrdClass {
  id                   String     @id @default(uuid())
  name                 String     @unique
  hitDie               String
  primaryAbilities     String[]
  savingThrows         String[]
  armorProficiencies   String[]
  weaponProficiencies  String[]
  skillChoices         String[]
  toolProficiencies    String[]
  numSkillChoices      Int        @default(2)
  description          String?
  features             Json?
  spellcasting         Json?
  equipmentChoices     Json?
  subclassLevel        Int?
  source               String     @default("SRD 5.2.1")

  subclasses Subclass[]

  @@map("srd_classes")
}

model Race {
  id              String    @id @default(uuid())
  name            String    @unique
  speed           Int
  size            String
  abilityBonuses  Json?
  traits          Json?
  languages       String[]
  description     String?
  age             String?
  alignment       String?
  sizeDescription String?
  source          String    @default("SRD 5.2.1")

  subraces Subrace[]

  @@map("races")
}

model Subclass {
  id          String  @id @default(uuid())
  name        String  @unique
  classId     String
  description String?
  features    Json?
  spellList   Json?
  source      String  @default("SRD 5.2.1")

  srdClass SrdClass @relation(fields: [classId], references: [id])

  @@map("subclasses")
}

model Subrace {
  id             String  @id @default(uuid())
  name           String  @unique
  raceId         String
  description    String?
  abilityBonuses Json?
  traits         Json?
  source         String  @default("SRD 5.2.1")

  race Race @relation(fields: [raceId], references: [id])

  @@map("subraces")
}

model Background {
  id                String   @id @default(uuid())
  name              String   @unique
  description       String?
  skillProficiencies String[]
  toolProficiencies  String[]
  languages         Int      @default(0)
  equipment         String?
  feature           Json?
  personalityTraits String[]
  ideals            String[]
  bonds             String[]
  flaws             String[]
  source            String   @default("SRD 5.2.1")

  @@map("backgrounds")
}

model Feat {
  id           String  @id @default(uuid())
  name         String  @unique
  description  String?
  prerequisite String?
  benefits     Json?
  source       String  @default("SRD 5.2.1")

  @@map("feats")
}

model Condition {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  bullets     String[]
  source      String   @default("SRD 5.2.1")

  @@map("conditions")
}

model Skill {
  id          String @id @default(uuid())
  name        String @unique
  ability     String
  description String?
  source      String @default("SRD 5.2.1")

  @@map("skills")
}

model Language {
  id              String  @id @default(uuid())
  name            String  @unique
  type            String
  typicalSpeakers String?
  script          String?
  source          String  @default("SRD 5.2.1")

  @@map("languages")
}

// ── Audit Log ─────────────────────────────────────────

model AuditLog {
  id        String      @id @default(uuid())
  userId    String
  username  String
  action    AuditAction
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
