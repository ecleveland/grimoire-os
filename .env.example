# PostgreSQL
DATABASE_URL=postgresql://grimoire:grimoire@localhost:5432/grimoire_os

# Auth (JWT_SECRET is required — the backend will not start without it)
JWT_SECRET=               # Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_EXPIRES_IN=24h

# CORS
FRONTEND_URL=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
